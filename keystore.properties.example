# Copy this file to keystore.properties (which is gitignored) and fill in values
# to produce signed release builds. If keystore.properties is absent,
# release builds fall back to the debug signing config so the project
# always builds.
#
# Generate an upload keystore with:
#   keytool -genkey -v -keystore my-upload.jks -keyalg RSA \
#     -keysize 2048 -validity 10000 -alias upload

storeFile=my-upload.jks
storePassword=
keyAlias=upload
keyPassword=
